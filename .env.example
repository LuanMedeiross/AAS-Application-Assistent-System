# Copie para .env e preencha. O .env NUNCA vai para o git (ver .gitignore).

# DeepSeek (ranking + geração de CV/carta)
DEEPSEEK_API_KEY=

# 2Captcha (acionado quando uma plataforma bloquear o canal browser)
CAPTCHA_API_KEY=

# Trava de segurança do envio de candidatura. Deixe 'false' até estar logado e supervisionando.
# Com 'false', "Aprovar e enviar" roda em DRY-RUN (não envia nada).
ALLOW_REAL_SUBMIT=false

# InHire é por empresa: liste os slugs das empresas-alvo (ex.: minhaempresa em minhaempresa.inhire.app)
INHIRE_TENANTS=

# SMTP (canal email direto — Fase 7)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
