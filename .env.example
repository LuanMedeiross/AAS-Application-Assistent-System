# Copie para .env e preencha. O .env NUNCA vai para o git (ver .gitignore).

# LLM provider — qualquer endpoint compatível com OpenAI (DeepSeek por padrão, ou servidor local).
# Para servidor local, use uma chave dummy não-vazia (ex.: "ollama").
LLM_API_KEY=
# URL base da API. Padrão: https://api.deepseek.com. Para modelos locais:
#   Ollama:    http://localhost:11434/v1
#   vLLM:      http://localhost:8000/v1
#   LM Studio: http://localhost:1234/v1
# LLM_BASE_URL=https://api.deepseek.com
# Modelos por etapa (opcional; têm default do DeepSeek). Para local, use o nome do modelo baixado.
# MODEL_RANK=deepseek-chat         # ranking/elegibilidade (rápido, barato)
# MODEL_GENERATE=deepseek-reasoner # CV/carta/formulário (qualidade)
# Modo JSON da saída: auto (padrão) | on | off. Use 'off' para servidores locais que rejeitam
# response_format=json_object (o cliente ainda parseia a resposta).
# LLM_JSON_MODE=auto
# Robustez (opcional; têm default). Timeout por tentativa (s) e nº de retries.
# LLM_TIMEOUT=180
# LLM_MAX_RETRIES=3

# 2Captcha (acionado quando uma plataforma bloquear o canal browser)
CAPTCHA_API_KEY=

# Trava de segurança do envio de candidatura. Deixe 'false' até estar logado e supervisionando.
# Com 'false', "Aprovar e enviar" roda em DRY-RUN (não envia nada).
ALLOW_REAL_SUBMIT=false

# InHire é por empresa: liste os slugs das empresas-alvo (ex.: minhaempresa em minhaempresa.inhire.app)
INHIRE_TENANTS=

# SMTP (canal email direto — Fase 7)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
